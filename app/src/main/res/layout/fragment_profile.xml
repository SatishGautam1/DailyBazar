<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="96dp">

            <!-- ── HEADER BAND ────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorPrimaryContainer"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="28dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_big_avatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_profile"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="3dp" />

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/loading"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <!-- KYC Status Chip — color set programmatically -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_kyc_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Unverified"
                    android:fontFamily="@font/mukta_medium"
                    android:textColor="@android:color/white"
                    android:clickable="false"
                    android:focusable="false"
                    style="@style/Widget.Material3.Chip.Assist" />

            </LinearLayout>

            <!-- ── LAST SYNCED ───────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_history"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_last_synced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Last synced: —"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:fontFamily="@font/mukta_regular"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- ── BASIC INFO CARD ─────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Email (Read Only - Primary Key) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address (Login ID)"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:fontFamily="@font/mukta_medium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tv_profile_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="…"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:fontFamily="@font/mukta_regular" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Phone -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone Number"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:fontFamily="@font/mukta_medium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tv_profile_phone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Not set"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:fontFamily="@font/mukta_regular" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="14dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:fontFamily="@font/mukta_medium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tv_profile_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Not set"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:fontFamily="@font/mukta_regular" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── KYC DOCUMENTS CARD ─────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verification Documents"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:fontFamily="@font/montserrat_semibold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp" />

                    <!-- Citizenship Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Citizenship (Front/Back)"
                            android:fontFamily="@font/mukta_medium"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_status_citizenship"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Missing"
                            android:fontFamily="@font/mukta_bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:layout_marginBottom="12dp" />

                    <!-- NID Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="National ID (NID)"
                            android:fontFamily="@font/mukta_medium"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tv_status_nid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Missing"
                            android:fontFamily="@font/mukta_bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── KYC REJECTION REASON CARD (shown only when rejected) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_rejection_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/design_default_color_error"
                app:cardBackgroundColor="?attr/colorErrorContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rejection Reason"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:fontFamily="@font/mukta_bold" />

                    <TextView
                        android:id="@+id/tv_rejection_reason"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:fontFamily="@font/mukta_regular" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── UPLOAD / UPDATE KYC BUTTON ───────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_profile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:text="Upload KYC Documents"
                android:fontFamily="@font/montserrat_semibold"
                style="@style/Widget.Material3.Button"
                app:cornerRadius="14dp" />

            <!-- ── SIGN OUT ───────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:text="@string/sign_out"
                android:fontFamily="@font/montserrat_semibold"
                android:textColor="@color/brand_error"
                app:strokeColor="@color/brand_error"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>