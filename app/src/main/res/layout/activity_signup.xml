<?xml version="1.0" encoding="utf-8"?>
<!--
    KEY KEYBOARD FIX:
    - topBar is a fixed FrameLayout child at the top (elevation = 4dp so it floats above scroll).
    - NestedScrollView fills the whole screen with paddingTop set in Java = statusBar + toolbarHeight.
    - adjustResize shrinks the window so the NestedScrollView gains free space above the keyboard.
    - The user always sees the focused field because NestedScrollView auto-scrolls focused views into view.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- ── SCROLLABLE FORM (full-screen, paddingTop set in Java) ─── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false">

        <!-- FIX: Increased paddingBottom from 48dp to 150dp.
             This acts as an invisible cushion, giving the NestedScrollView enough
             room to push the "Confirm Password" field above the keyboard. -->
        <LinearLayout
            android:id="@+id/formContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="150dp">

            <!-- Spacer: pushes content below the floating topBar (set in Java) -->
            <View
                android:id="@+id/formTopSpacer"
                android:layout_width="match_parent"
                android:layout_height="88dp" />

            <!-- Page title -->
            <TextView
                android:id="@+id/tvSignupTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/signup_title"
                android:textSize="28sp"
                android:fontFamily="@font/montserrat_bold"
                android:textColor="@color/charcoal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:text="@string/signup_subtitle"
                android:textSize="13sp"
                android:fontFamily="@font/mukta_regular"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <!-- ── SECTION: Personal Info ──────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/brand_secondary_container"
                app:strokeWidth="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="@string/signup_section_personal"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textColor="@color/brand_on_secondary_container" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFullName"
                style="@style/Widget.DailyBazar.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/signup_full_name_hint"
                app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                app:startIconTint="?attr/colorPrimary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:fontFamily="@font/mukta_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPhone"
                style="@style/Widget.DailyBazar.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/signup_phone_hint"
                app:startIconDrawable="@android:drawable/ic_menu_call"
                app:startIconTint="?attr/colorPrimary"
                app:prefixText="+977 ">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:maxLength="10"
                    android:fontFamily="@font/mukta_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.DailyBazar.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/signup_email_hint"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="?attr/colorPrimary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:fontFamily="@font/mukta_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── SECTION: Security ──────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/brand_primary_container"
                app:strokeWidth="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="@string/signup_section_security"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textColor="@color/brand_on_primary_container" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.DailyBazar.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/signup_password_hint"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="?attr/colorPrimary"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:fontFamily="@font/mukta_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/Widget.DailyBazar.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/signup_confirm_password_hint"
                app:startIconDrawable="@android:drawable/ic_lock_lock"
                app:startIconTint="?attr/colorPrimary"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:fontFamily="@font/mukta_regular" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Create Account CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAccount"
                style="@style/Widget.DailyBazar.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/signup_button"
                android:fontFamily="@font/montserrat_semibold" />

            <!-- Sign in link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/signup_have_account"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:fontFamily="@font/mukta_regular" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoToLogin"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/signup_log_in"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="14sp"
                    android:fontFamily="@font/montserrat_semibold" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── FLOATING TOP BAR (drawn on top of scroll, elevation keeps it above) ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="?android:attr/colorBackground"
        android:orientation="vertical"
        android:elevation="4dp">

        <!-- Status bar spacer (height set in Java) -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <!-- Toolbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_back_arrow"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="22dp"
                android:contentDescription="@string/back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/signup_title"
                android:textSize="17sp"
                android:fontFamily="@font/montserrat_semibold"
                android:textColor="?attr/colorOnSurface" />

        </LinearLayout>

        <!-- Brand accent line at bottom of toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="?attr/colorPrimaryContainer" />

    </LinearLayout>

</FrameLayout>