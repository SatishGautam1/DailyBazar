<?xml version="1.0" encoding="utf-8"?>
<!--
    Navigation Drawer header.
    IDs referenced in MainActivity.java:
      nav_header_avatar      → ShapeableImageView (profile photo)
      nav_header_name        → TextView (display name)
      nav_header_email       → TextView (email address)
      nav_header_status_dot  → View (green active dot)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorPrimary"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="40dp"
    android:paddingBottom="24dp">

    <!-- Avatar + status dot overlay -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/nav_header_avatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView"
            app:strokeColor="@color/white"
            app:strokeWidth="2.5dp" />

        <!-- Green online dot — bottom-right corner -->
        <View
            android:id="@+id/nav_header_status_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_status_dot_bordered"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Display name -->
    <TextView
        android:id="@+id/nav_header_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Daily-Bazar User"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:fontFamily="@font/montserrat_bold" />

    <!-- Email — shown below name as requested -->
    <TextView
        android:id="@+id/nav_header_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="user@email.com"
        android:textColor="@color/white"
        android:alpha="0.75"
        android:textSize="13sp"
        android:fontFamily="@font/mukta_regular" />

</LinearLayout>