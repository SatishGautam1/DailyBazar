<?xml version="1.0" encoding="utf-8"?>
<!--
    item_market_card.xml — Premium redesign
    Design direction: Refined editorial dark-capable card
    - Floating image with generous corner radius
    - Pill category badge with brand tint
    - Price in dominant type, trend as color-coded pill
    - Ghost-stroke CTA button with icon
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_market_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:rippleColor="?attr/colorPrimary"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="0.8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image container with rounded top only -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_storefront"
                app:shapeAppearance="@style/ShapeAppearance.ProductImage.TopRounded"
                tools:background="@color/brand_primary_container" />

            <!-- Trend pill — floated top-right over image -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_trend_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                app:cardCornerRadius="100dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#CC000000"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/iv_trend_icon"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_trend_up"
                        android:contentDescription="Trend" />

                    <!-- Trend text set dynamically; shown as price delta hint -->
                    <TextView
                        android:id="@+id/tv_trend_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Up"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="@font/montserrat_semibold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- Content block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <!-- Category pill -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_category"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginBottom="8dp"
                android:textSize="10sp"
                android:fontFamily="@font/mukta_medium"
                style="@style/Widget.Material3.Chip.Assist"
                app:chipMinHeight="24dp"
                app:chipBackgroundColor="?attr/colorPrimaryContainer"
                app:chipStrokeWidth="0dp"
                tools:text="Vegetable" />

            <!-- Product name -->
            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.1"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="@font/montserrat_semibold"
                tools:text="Tomato" />

            <!-- Price row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_product_price"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="17sp"
                    android:textColor="?attr/colorPrimary"
                    android:fontFamily="@font/montserrat_bold"
                    tools:text="Rs. 120/kg" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.6dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- CTA button — full width, outlined ghost style -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_analysis"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/view_analysis"
                android:textSize="12sp"
                android:fontFamily="@font/mukta_medium"
                app:icon="@drawable/ic_trend_up"
                app:iconSize="14dp"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>