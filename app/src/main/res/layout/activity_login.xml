<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ── GREEN HEADER BAND (fixed, 280dp) ─────── -->
    <LinearLayout
        android:id="@+id/headerBand"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="top"
        android:background="?attr/colorPrimary"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="112dp">
        <!-- FIX 1: Increased from 72dp to 112dp to pull text UP and clear the floating card -->

        <!-- Status bar inset spacer (height set in Java) -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <!-- Decorative top-right circle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:visibility="gone" />

        <!-- Rupee badge -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/brand_secondary"
            app:strokeWidth="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="₨"
                android:textColor="@color/brand_on_secondary"
                android:textSize="20sp"
                android:fontFamily="@font/montserrat_bold" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvHeaderAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/brand_on_primary"
            android:textSize="30sp"
            android:fontFamily="@font/montserrat_bold"
            android:letterSpacing="0.01" />

        <TextView
            android:id="@+id/tvHeaderTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/login_welcome_subtitle"
            android:textColor="@color/brand_on_primary"
            android:textSize="13sp"
            android:alpha="0.75"
            android:fontFamily="@font/mukta_regular"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- ── SCROLLABLE AREA — starts at 196dp so card overlaps header ── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="196dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <!-- FIX 2: Added paddingBottom="150dp".
             This acts as an invisible cushion. When the keyboard opens,
             the scrollview now has plenty of room to scroll the focused EditText upwards. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="150dp">

            <!-- ── THE FLOATING CARD ─────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="30dp"
                    android:paddingBottom="24dp">

                    <!-- Card header text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_welcome_title"
                        android:textSize="24sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="24dp"
                        android:text="@string/login_enter_creds"
                        android:textSize="13sp"
                        android:fontFamily="@font/mukta_regular"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:lineSpacingMultiplier="1.4" />

                    <!-- Email field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/Widget.DailyBazar.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/login_email_hint"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="?attr/colorPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:imeOptions="actionNext"
                            android:singleLine="true"
                            android:fontFamily="@font/mukta_regular" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/Widget.DailyBazar.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/login_password_hint"
                        app:startIconDrawable="@android:drawable/ic_lock_lock"
                        app:startIconTint="?attr/colorPrimary"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:singleLine="true"
                            android:fontFamily="@font/mukta_regular" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot password -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForgotPassword"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="0dp"
                        android:minHeight="36dp"
                        android:text="@string/login_forgot_password"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="12sp"
                        android:fontFamily="@font/mukta_medium" />

                    <!-- Sign In CTA -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        style="@style/Widget.DailyBazar.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="6dp"
                        android:text="@string/login_button"
                        android:fontFamily="@font/montserrat_semibold" />

                    <!-- Divider: ── or ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="?attr/colorOutlineVariant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:text="or"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                            android:fontFamily="@font/mukta_regular" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="?attr/colorOutlineVariant" />

                    </LinearLayout>

                    <!-- Sign up prompt -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/login_no_account"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp"
                            android:fontFamily="@font/mukta_regular" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGoToSignUp"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/login_sign_up"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat_semibold" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>